// Programa que calcula el perimetro y area de un rectangulo dada su base y altura //
Algoritmo calcula_perimetro_area
	Escribir "Digite base del rectangulo"
	leer base
	Escribir "Digite la altura del rectangulo"
	Leer altura 
	area = base * altura
	Perimetro = 2*(base+altura)
	Escribir " El resultado del area es: ",area 
	Escribir "Elresultado del perimetro es: ",Perimetro
	FINALGORITMO
