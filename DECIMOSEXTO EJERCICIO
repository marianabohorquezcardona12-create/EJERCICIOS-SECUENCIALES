// Programa de tiempoalcancevehiculos//

Proceso TiempoAlcanceVehiculos
Definir v1, v2, d, tiempoHoras, tiempoMinutos Como Real
    
Escribir "Digite la velocidad del vehículo 1 (km/h):"
Leer v1
    
Escribir "Digite la velocidad del vehículo 2 (km/h):"
Leer v2
    
Escribir "Digite la distancia entre los vehículos (km):"
Leer d
    
tiempoHoras <- d / (v1 - v2)
tiempoMinutos <- tiempoHoras * 60
    
Escribir "El tiempo en que el vehículo más rápido alcanza al otro es: ", tiempoMinutos, " minutos"

FinProceso
