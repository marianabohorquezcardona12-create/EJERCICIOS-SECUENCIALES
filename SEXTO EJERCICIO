//Programa para calcular la media//
Proceso CalcularMedia
Definir n1, n2, n3, media Como Real
    
Escribir "Digite el primer número:"
Leer n1
    
Escribir "Digite el segundo número:"
Leer n2
    
Escribir "Digite el tercer número:"
Leer n3
    
media <- (n1 + n2 + n3) / 3
    
Escribir "La media es: ", media
FinProceso
