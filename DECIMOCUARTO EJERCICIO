//programa que invierte un numero de dos cifras//

Proceso NumeroInvertido
Definir num, decenas, unidades, invertido Como Entero
    
Escribir "Digite un número de dos cifras:"
Leer num
    
decenas <- trunc(num / 10)
unidades <- num % 10
    
invertido <- (unidades * 10) + decenas
    
Escribir "El número invertido es: ", invertido
FinProceso
