//programa que calcula distancia entre dos puntos en el plano//
 Definir x1, y1, x2, y2, d Como Real

Escribir "Digite x1:"
Leer x1
    
Escribir "Digite y1:"
Leer y1
    
Escribir "Digite x2:"
Leer x2
    
Escribir "Digite y2:"
Leer y2
    
d <- raiz((x2 - x1)^2 + (y2 - y1)^2)
    
Escribir "La distancia entre los puntos es: ", d
FinProceso
